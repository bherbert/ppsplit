				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run Shell Script.action</string>
				<key>ActionName</key>
				<string>Run Shell Script</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>#!/bin/bash

ERROR_SOUND=/System/Library/Sounds/Sosumi.aiff

######## Get YouTube video URL

# Ask for URL with a custom message + title
URL=$(osascript -e 'Tell application "System Events" to display dialog "Enter the YouTube URL to process for this folder:" default answer ""' 2&gt;/dev/null \
    -e 'text returned of result' 2&gt;/dev/null)
if [ -z "$URL" ]; then
  echo "User canceled. Exiting."
  exit 0
fi

######## Extract video ID from URL (supports all common YouTube URL formats)

# Supported formats:
#   https://www.youtube.com/watch?v=VIDEO_ID          (standard)
#   https://www.youtube.com/watch?v=VIDEO_ID&amp;list=... (with extra params)
#   https://www.youtube.com/watch?list=...&amp;v=VIDEO_ID (v param not first)
#   https://youtu.be/VIDEO_ID                         (shortened)
#   https://www.youtube.com/embed/VIDEO_ID            (embed)
VIDEO_ID=""

# Store patterns in variables to avoid bash 3.2 parser issues with &amp; in [[ =~ ]]
RE_WATCH='[?&amp;]v=([^&amp;]+)'
RE_SHORT='youtu\.be/([^?&amp;]+)'
RE_EMBED='youtube\.com/embed/([^?&amp;]+)'

if [[ "$URL" =~ $RE_WATCH ]]; then
    VIDEO_ID="${BASH_REMATCH[1]}"
elif [[ "$URL" =~ $RE_SHORT ]]; then
    VIDEO_ID="${BASH_REMATCH[1]}"
elif [[ "$URL" =~ $RE_EMBED ]]; then
    VIDEO_ID="${BASH_REMATCH[1]}"
fi

if [[ -z "$VIDEO_ID" ]]; then
    osascript -e "display notification \"Could not find a YouTube video ID in the URL\" with title \"URL Error\" subtitle \"$URL\""
    afplay $ERROR_SOUND
    exit 0
fi

NEW_URL="https://www.youtube.com/watch?v=$VIDEO_ID"

######## Start processing

#VERBOSE="-v"  # or leave empty "" to disable verbose
VERBOSE=""  # or leave empty "" to disable verbose

LOGFILE="$HOME/Library/Logs/yt-dlp.log"

# Detect architecture to select correct Homebrew prefix
if [[ "$(uname -m)" == "arm64" ]]; then
    HOMEBREW_BIN="/opt/homebrew/bin"
else
    HOMEBREW_BIN="/usr/local/bin"
fi
FFMPEG="--ffmpeg-location $HOMEBREW_BIN"
YTDLP="$HOMEBREW_BIN/yt-dlp"

echo "================ $(date '+%Y-%m-%d %H:%M:%S')" &gt;&gt; $LOGFILE
echo "Input items: $@" &gt;&gt; $LOGFILE

# Process each selected folder
for FOLDER in "$@"; do
	afplay /System/Library/Sounds/Funk.aiff

    echo "Running script on folder: $FOLDER with URL: $NEW_URL"
	$YTDLP $VERBOSE --no-progress $FFMPEG -o "%(title)s.%(ext)s" -P "$FOLDER" -S res,ext:mp4:m4a --recode mp4 "$NEW_URL" &gt;&gt; $LOGFILE 2&gt;&amp;1

	afplay /System/Library/Sounds/Glass.aiff
done
</string>
